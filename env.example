# ── Telemt backend(s) ─────────────────────────────────────────────────────────
# Single-server setup (legacy form, backward compatible):
#   TELEMT_API_BASE_URL=http://127.0.0.1:9091
#   TELEMT_API_AUTH_HEADER=
#
# Multi-server setup — use numbered suffixes (1, 2, 3, …):
#   The UI will show a server selector in the sidebar.
#   The primary backend (lowest suffix) is used for the readiness probe
#   and server-side rendered pages.

TELEMT_API_BASE_URL_1=http://server1:9091
TELEMT_API_AUTH_HEADER_1=secret1
TELEMT_API_LABEL_1=Production

# TELEMT_API_BASE_URL_2=http://server2:9091
# TELEMT_API_AUTH_HEADER_2=secret2
# TELEMT_API_LABEL_2=Staging

# ── OIDC provider ──────────────────────────────────────────────────────────────
# Issuer URL of your OIDC provider (Keycloak, Authentik, Dex, Google, etc).
OIDC_ISSUER=https://your-oidc-provider.example.com

# Client credentials registered with your OIDC provider.
OIDC_CLIENT_ID=telemt-frontend
OIDC_CLIENT_SECRET=change-me

# ── Auth.js ────────────────────────────────────────────────────────────────────
# Random secret used to sign session JWTs.
# Generate with: openssl rand -base64 32
AUTH_SECRET=change-me-generate-with-openssl-rand-base64-32

# Public base URL of this Next.js application (used for OIDC redirect_uri).
NEXTAUTH_URL=http://localhost:3000

# ── Optional ───────────────────────────────────────────────────────────────────
# Space-separated OIDC scopes. Defaults to "openid profile email".
# OIDC_SCOPE=openid profile email

# Comma-separated allowed e-mail domains. Empty = allow all.
# OIDC_ALLOWED_EMAIL_DOMAINS=example.com,corp.example.com

# Comma-separated allowed OIDC groups claim values. Empty = allow all.
# Requires the provider to include a "groups" claim in the ID token.
# OIDC_ALLOW_GROUPS=telemt-admins,platform-team
