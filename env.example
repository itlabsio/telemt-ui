# ── Telemt backend ─────────────────────────────────────────────────────────────
# Base URL of the Telemt control API (no trailing slash).
TELEMT_API_BASE_URL=http://127.0.0.1:9091

# Exact value for the Authorization header configured in [server.api].auth_header.
# Leave empty to disable header auth.
TELEMT_API_AUTH_HEADER=

# ── OIDC provider ──────────────────────────────────────────────────────────────
# Issuer URL of your OIDC provider (Keycloak, Authentik, Dex, Google, etc).
AUTH_ISSUER=https://your-oidc-provider.example.com

# Client credentials registered with your OIDC provider.
AUTH_CLIENT_ID=telemt-frontend
AUTH_CLIENT_SECRET=change-me

# ── Auth.js ────────────────────────────────────────────────────────────────────
# Random secret used to sign session JWTs.
# Generate with: openssl rand -base64 32
AUTH_SECRET=change-me-generate-with-openssl-rand-base64-32

# Public base URL of this Next.js application (used for OIDC redirect_uri).
NEXTAUTH_URL=http://localhost:3000

# ── Optional ───────────────────────────────────────────────────────────────────
# Space-separated OIDC scopes. Defaults to "openid profile email".
# AUTH_SCOPE=openid profile email

# Comma-separated allowed e-mail domains. Empty = allow all.
# AUTH_ALLOWED_EMAIL_DOMAINS=example.com,corp.example.com
